# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/nz_cultural_events
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nz_cultural_events
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT Configuration
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# Server Configuration
PORT=3000
NODE_ENV=development

# Upload Configuration
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Admin Configuration
ADMIN_EMAIL=admin@nzevents.co.nz
ADMIN_PASSWORD=ChangeThisPassword123!

# Facebook Page Scraper (scripts/fb_import.py)
# Set FB_PAGE to your page name or URL slug — no login needed for public pages
FB_PAGE=NZSLCulturalFoundation
# Optional: add your personal FB login if the page blocks public scraping
# FB_EMAIL=you@email.com
# FB_PASSWORD=yourpassword